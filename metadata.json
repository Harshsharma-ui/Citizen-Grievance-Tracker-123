import React, { useState, useMemo, useEffect } from 'react';
import { MapContainer, TileLayer, Marker, Popup, ZoomControl, useMap } from 'react-leaflet';
import L from 'leaflet';
import 'leaflet.heat';
import { Complaint } from '../../lib/supabase';
import { cn } from '../../lib/utils';
import { Map as MapIcon, AlertCircle, Target } from 'lucide-react';
import 'leaflet/dist/leaflet.css';

// Fix for default marker icons in Leaflet with Webpack/Vite
import icon from 'leaflet/dist/images/marker-icon.png';
import iconShadow from 'leaflet/dist/images/marker-shadow.png';

let DefaultIcon = L.icon({
    iconUrl: icon,
    shadowUrl: iconShadow,
    iconSize: [25, 41],
    iconAnchor: [12, 41]
});

L.Marker.prototype.options.icon = DefaultIcon;

const center: [number, number] = [22.7196, 75.8577];

function FixMapSize() {
  const map = useMap();
  useEffect(() => {
    const timer = setTimeout(() => {
      map.invalidateSize();
    }, 250);
    return () => clearTimeout(timer);
  }, [map]);
  return null;
}

function HeatmapLayer({ points }: { points: [number, number, number][] }) {
  const map = useMap();

  useEffect(() => {
    if (!map || !points.length) return;
    
    // @ts-ignore - L.heatLayer is added by leaflet.heat import
    if (typeof L.heatLayer !== 'function') {
      console.warn('L.heatLayer is not available');
      return;
    }

    // @ts-ignore
    const heatLayer = L.heatLayer(points, {
      radius: 25,
      blur: 15,
      maxZoom: 17,
      gradient: {
        0.4: 'blue',
        0.6: 'cyan',
        0.7: 'lime',
        0.8: 'yellow',
        1.0: 'red'
      }
    }).addTo(map);

    return () => {
      map.removeLayer(heatLayer);
    };
  }, [map, points]);

  return null;
}

function ChangeView({ center, zoom }: { center: [number, number], zoom: number }) {
  const map = useMap();
  useEffect(() => {
    map.flyTo(center, zoom, { duration: 1.5 });
  }, [center, zoom, map]);
  return null;
}

export default function MunicipalHeatmap({ complaints }: { complaints: Complaint[] }) {
  const [filter, setFilter] = useState<string>('all');
  const [mapCenter, setMapCenter] = useState<[number, number]>(center);
  const [zoom, setZoom] = useState(12);
  const [adminPos, setAdminPos] = useState<[number, number] | null>(null);
  const [locating, setLocating] = useState(false);
  
  const handleLocateMe = () => {
    if (!navigator.geolocation) return;
    setLocating(true);
    navigator.geolocation.getCurrentPosition(
      (pos) => {
        const newPos: [number, number] = [pos.coords.latitude, pos.coords.longitude];
        setMapCenter(newPos);
        setAdminPos(newPos);
        setZoom(15);
        setLocating(false);
      },
      () => setLocating(false),
      { enableHighAccuracy: true }
    );
  };
  
  const filteredComplaints = useMemo(() => 
    filter === 'all' 
      ? complaints 
      : complaints.filter(c => c.category === filter),
    [complaints, filter]
  );

  const heatmapPoints = useMemo(() => 
    filteredComplaints.map(c => [
      c.latitude, 
      c.longitude, 
      c.severity === 'high' ? 1.0 : c.severity === 'medium' ? 0.6 : 0.3
    ] as [number, number, number]),
    [filteredComplaints]
  );

  const categories = useMemo(() => Array.from(new Set(complaints.map(c => c.category))), [complaints]);

  const getMarkerIcon = (severity: string) => {
    const color = severity === 'high' ? '#ef4444' : severity === 'medium' ? '#f59e0b' : '#3b82f6';
    return L.divIcon({
      className: 'custom-div-icon',
      html: `<div style="background-color: ${color}; width: 12px; height: 12px; border-radius: 50%; border: 2px solid white; box-shadow: 0 0 4px rgba(0,0,0,0.3);"></div>`,
      iconSize: [12, 12],
      iconAnchor: [6, 6]
    });
  };

  const adminIcon = L.divIcon({
    className: 'admin-marker',
    html: `<div style="background-color: #6366f1; width: 16px; height: 16px; border-radius: 50%; border: 3px solid white; box-shadow: 0 0 10px rgba(99, 102, 241, 0.6); position: relative;">
      <div style="position: absolute; inset: -8px; background-color: #6366f1; opacity: 0.3; border-radius: 50%; animation: pulse 2s infinite;"></div>
    </div>`,
    iconSize: [16, 16],
    iconAnchor: [8, 8]
  });

  return (
    <div className="relative h-full w-full bg-slate-900 rounded-[24px] overflow-hidden border-2 border-slate-100 shadow-inner isolate z-0 transition-colors duration-300">
      {/* Overlays */}
      <div className="absolute top-4 left-4 z-[1000] space-y-4 pointer-events-none w-[calc(100%-2rem)] max-w-xs">
        <div className="bg-slate-900/90 backdrop-blur-xl p-4 rounded-[20px] shadow-2xl border border-white/10 pointer-events-auto">
          <div className="flex items-center space-x-2 mb-3">
            <div className="w-2 h-2 bg-red-500 rounded-full animate-pulse" />
            <h3 className="text-[10px] font-black text-white uppercase tracking-[0.2em]">Operational Heatmap</h3>
          </div>
          
          <div className="space-y-3">
            <div>
              <p className="text-[8px] font-black text-slate-500 uppercase tracking-widest mb-1.5">Filter by Category</p>
              <div className="flex flex-wrap gap-1">
                <button 
                  onClick={() => setFilter('all')}
                  className={cn(
                    "px-2 py-1 text-[9px] font-bold rounded-lg border transition-all uppercase tracking-tighter",
                    filter === 'all' ? "bg-indigo-600 text-white border-indigo-600" : "bg-white/5 text-slate-400 border-white/10 hover:bg-white/10"
                  )}
                >
                  All
                </button>
                {categories.map(cat => (
                  <button 
                    key={cat}
                    onClick={() => setFilter(cat)}
                    className={cn(
                      "px-2 py-1 text-[9px] font-bold rounded-lg border transition-all uppercase tracking-tighter",
                      filter === cat ? "bg-indigo-600 text-white border-indigo-600" : "bg-white/5 text-slate-400 border-white/10 hover:bg-white/10"
                    )}
                  >
                    {cat}
                  </button>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <div className="absolute bottom-4 right-4 z-[1000] pointer-events-auto flex flex-col space-y-2">
        <button 
          onClick={handleLocateMe}
          className="bg-white dark:bg-slate-800 p-3 rounded-xl shadow-xl text-indigo-600 hover:bg-indigo-50 transition-colors"
        >
          <Target size={20} className={locating ? "animate-spin" : ""} />
        </button>
      </div>

      <div className="h-full w-full relative z-0">
        <MapContainer 
          center={mapCenter} 
          zoom={zoom} 
          scrollWheelZoom={true}
          style={{ height: '100%', width: '100%' }}
          zoomControl={false}
        >
          <FixMapSize />
          <ChangeView center={mapCenter} zoom={zoom} />
          <TileLayer
            attribution='&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>'
            url="https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png"
          />
          <ZoomControl position="bottomright" />
          <HeatmapLayer points={heatmapPoints} />
          
          {adminPos && (
            <Marker position={adminPos} icon={adminIcon}>
              <Popup>
                <div className="p-1 font-bold text-xs">Admin Location (You)</div>
              </Popup>
            </Marker>
          )}

          {filteredComplaints.map(c => (
            <Marker 
              key={c.id} 
              position={[c.latitude, c.longitude]}
              icon={getMarkerIcon(c.severity)}
            >
              <Popup>
                <div className="p-2 max-w-[240px]">
                  {c.image_url && (
                    <div className="relative rounded-lg overflow-hidden mb-2 shadow-sm">
                      <img src={c.image_url} alt="Issue" className="w-full h-24 object-cover" />
                    </div>
                  )}
                  <div className="flex items-center space-x-2 mb-1">
                    <span className={cn(
                      "px-1.5 py-0.5 rounded text-[7px] font-black uppercase tracking-widest",
                      c.severity === 'high' ? "bg-red-100 text-red-600" : "bg-amber-100 text-amber-600"
                    )}>
                      {c.severity}
                    </span>
                  </div>
                  <h4 className="font-black text-slate-900 uppercase tracking-tight text-xs mb-0.5">{c.category}</h4>
                  <p className="text-[10px] text-slate-500 font-medium line-clamp-2 leading-tight">{c.description}</p>
                </div>
              </Popup>
            </Marker>
          ))}
        </MapContainer>
      </div>
    </div>
  );
}
